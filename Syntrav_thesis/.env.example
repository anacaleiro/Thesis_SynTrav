# Copy this file to .env and fill in your API keys.
# The pipeline uses Groq (primary), with optional OpenAI, Anthropic, DeepSeek, and Qwen providers.

groq_cot=your_groq_api_key_here
groq_self_consistency=your_groq_api_key_here
groq_generation=your_groq_api_key_here
groq_free=your_groq_api_key_here

# Optional — only needed for multi-model comparison experiments
openai=your_openai_api_key_here
claude=your_anthropic_api_key_here
deepseek=your_deepseek_api_key_here
qwen=your_dashscope_api_key_here
